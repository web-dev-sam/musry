{
  "name": "@musry/bot",
  "private": true,
  "type": "module",
  "scripts": {
    "register": "bun --env-file ../../.env src/register-commands.ts",
    "dev": "bun --env-file ../../.env --watch src/index.ts",
    "start": "bun --env-file ../../.env src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint -c ../../.oxlintrc.json",
    "lint:fix": "oxlint -c ../../.oxlintrc.json --fix",
    "fmt": "oxfmt -c ../../.oxfmtrc.json"
  },
  "dependencies": {
    "@discordjs/voice": "latest",
    "discord.js": "^14.25.1",
    "lavalink-client": "^2.9.11"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^24.12.0",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "oxlint-tsgolint": "^0.18.1",
    "typescript": "^6.0.2"
  }
}

DISCORD_TOKEN=
CLIENT_ID=
# Optional: register commands instantly to a specific guild (development only)
GUILD_ID=
LAVALINK_HOST=localhost
LAVALINK_PORT=2333
LAVALINK_PASSWORD=
LAVALINK_SECURE=false
LAVALINK_YOUTUBE_OAUTH_TOKEN=
# Optional: enables full SoundCloud track playback (without these, SC tracks play as 30s previews)
# clientId: the client_id query param on any api-v2.soundcloud.com request in browser devtools
# oauthToken: the "OAuth <token>" value from the Authorization header on those same requests
SOUNDCLOUD_CLIENT_ID=
SOUNDCLOUD_OAUTH_TOKEN=
